# PoolConnection — environment variables
# Copy this file to `.env.local` and fill in real values for local dev.
# Cloudflare Pages reads its own copy from the dashboard
# (Settings → Environment variables, Production + Preview scopes).
#
# All Vite-injected env vars MUST be prefixed `VITE_` to be exposed to
# the browser bundle.

# Supabase project — the URL is safe to share, the anon key is
# publishable (RLS protects the data). Still kept in env vars so we
# can rotate or point preview deploys at a different project without
# a code change.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
